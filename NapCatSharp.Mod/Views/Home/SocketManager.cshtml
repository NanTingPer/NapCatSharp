@{
    ViewData["Title"] = "Socket Manager";
}
<div>
    <script src="/js/socketManager.js"></script>
    <h1> 欢迎访问链接管理器 </h1>
    <table>
        <tr>
            <td> socket名称 </td>
            <td> <input type="text" id="name" value="" required></td>
        </tr>
        <tr>
            <td> socket地址 </td>
            <td> <input type="text" id="url" value="" required></td>
        </tr>
        <tr>
            <td> socket密码 </td>
            <td> <input type="password" id="password" value=""></td>
        </tr>
        <tr>
            <td></td>
            <td> <input type="button" id="tj" value="创建" onclick="createSocket()"></td>
        </tr>
    </table>
    <div id="list"></div>
    <script>
        async function renderList() {
            /**
             * @@type { { name: string, uri: string, password: string, isEnable: boolean }[] | undefined }
             */
            let list = await socketList();
            if (list == undefined){
                return;
            }

            let html = `<table border-collapse="separate" style="border-spacing: 10px 5px;">`;
            let listElement = document.getElementById('list');
            list.forEach(s => {
                html += `<tr> <td style="padding: 10px;">`;
                html += `${s.name}</td><td style="padding: 10px;">`;
                html += `${s.uri}</td><td style="padding: 10px;">`;
                html += `<input type="button" value="链接" onclick="create(${s.name}, ${s.uri}, ${s.password})" </td>`; //${s.password}
                html += `</tr>`;
            })
            html += `</table>`;
            listElement.innerHTML = html;
        }
        async function createSocket() {
            let elements = {
                name: document.getElementById('name'),
                url: document.getElementById('url'),
                password: document.getElementById('password')
            }
            if(elements.name.value == "" || elements.url.value == ""){
                alert("名称或url不能为空");
                return;
            }
            await create(elements.name.value, elements.url.value, elements.password.value);
            Object.keys(elements).forEach(k => elements[k].value = "");
            renderList();
        }
    </script>
</div>